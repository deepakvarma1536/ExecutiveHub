PORT=5002
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/?appName=Cluster0
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# AI quiz generation — set at least one key (priority: Gemini > Groq > Ollama)
# Gemini free tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Groq free tier: https://console.groq.com  (14 400 req/day, no credit card)
GROQ_API_KEY=
# Ollama local fallback — requires `ollama serve` running locally
OLLAMA_URL=http://localhost:11434
