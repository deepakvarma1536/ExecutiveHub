# ─── LOCAL DEVELOPMENT ───────────────────────────────────────────
# Leave VITE_API_URL empty for local dev (Vite proxy handles it automatically)
VITE_API_URL=

# ─── PRODUCTION (Vercel) ─────────────────────────────────────────
# Set this to your Render backend URL after deploying to Render:
# VITE_API_URL=https://executivehub-server.onrender.com

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=
